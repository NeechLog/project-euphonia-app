# ============================================
# OAuth2.0 / OpenID Connect (OIDC) Configuration
# ============================================
# Copy this file to .env.oidc and update the values accordingly
# Keep this file secure and never commit sensitive data to version control
AUTH_CONFIG_DIR =/Users/gagan/projects/work/project-euphonia-app/conf.d
# ================
# Common Settings
# ================
# Base secret key used as fallback if provider-specific keys are not set
STATE_SECRET_KEY=SOMETHING_THAT_IS_COMMON_BUT_NOT_SAME_ACROSS_NODES

# JWT Configuration
JWT_SECRET=adfsgjjioi7489347329853&$^#sfdf
JWT_EXPIRE_HOURS=24

# Admin Configuration
ADMIN_EMAILS=gagan@nukreatech.com,gagan.bajpai@gmail.com,gagan@tarqwork.com,pkatoch@nukreatech.com



# ================
# Session Configuration
# ================
# Session cookie name
SESSION_COOKIE_NAME=EUPHONIA_SESSION
# Session lifetime in seconds (default: 7 days)
SESSION_LIFETIME=604800

# ================
# Security Settings
# ================
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://your-production-domain.com
ALLOWED_ORIGINS=*
# Enable/disable HTTPS only cookies (recommended: True in production)
SECURE_COOKIES=True
# Enable/disable HTTP only flag for cookies (recommended: True)
HTTP_ONLY_COOKIES=True
# Enable/disable SameSite attribute for cookies (recommended: 'lax' or 'strict')
SAME_SITE_COOKIES=lax


# Storage Configuration - all these variables are used for local storage of samples
# and other audio messages. On GCP, bucket name changes.

EUPHONIA_DIA_GCS_BUCKET=/Users/gagan/projects/work/suvani/samples
LOCAL_STORAGE_DIR=/Users/gagan/projects/work/suvani/samples
DATA_DIR=/Users/gagan/projects/work/suvani/samples
# Default Base Directory Configuration
DEFAULT_BASE_DIR=/Users/gagan/projects/work/suvani/samples
# Default Bucket Configuration
DEFAULT_BUCKET=/Users/gagan/projects/work/suvani/samples

# Audio Directory Configuration
TEMP_AUDIO_DIR=/Users/gagan/projects/work/suvani/requests
GOOD_AUDIO_DIR=/Users/gagan/projects/work/suvani/validated

# Default User Configuration
DEFAULT_HASH_ID=default_user_123





# Google Cloud Platform
PROJECT_ID=your-gcp-project-id
REGION=us-central1
ENDPOINT_ID=your-vertex-ai-endpoint-id

# Application Configuration
ENVIRONMENT=development
DEBUG=true
PYTHON_LOG_LEVEL=DEBUG
COOKIE_DOMAIN=localhost

# Testing
TESTING=true
DOTENV_PATH=/dev/null

# Model Configuration
TRANSCRIBE_MODEL=local
STORAGE=local
CLOUD=local

# Whisper Configuration
BASE_WHISPER_MODEL_TYPE=openai/whisper-small
LANGUAGE=en
MAX_NEW_TOKENS=256
CUSTOM_WHISPER_MODEL_PATH=custom_tiny_whisper_model

# Faster Whisper Configuration
faster_whisper_model_name_or_path=small
BEAM_SIZE=5

# DIA Model Configuration
GUIDANCE_SCALE_PARAM=4.0
TEMPERATURE_PARAM=1.8
TOP_P_PARAM=0.95
DEFAULT_SAMPLE_RATE=44100

# Vertex AI Model Configuration
config_SCALE_PARAM=0.3
DIADeployed=false


# VibeVAServer Configuration
VIBEVASERVER_ADDRESS=localhost:50051

# Application Configuration
DEFAULT_LOCALE=en-US

